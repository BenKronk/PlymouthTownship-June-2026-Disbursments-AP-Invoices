      <column caption='Calculation1' datatype='real' name='[Calculation_0276271191121930]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ATTR([Vendor (group) 2]) = &quot;Your Group Name&quot;&#13;&#10;THEN NULL&#13;&#10;ELSE SUM([Line_Amount])&#13;&#10;END' />
      </column>
      <column caption='Average Invoice Amount' datatype='real' name='[Calculation_0276271216394251]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Line_Amount])/COUNTD([Invoice_ID])' />
